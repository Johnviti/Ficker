APP_NAME=Ficker
APP_ENV=testing
APP_KEY=GERADA
APP_DEBUG=true
APP_URL=https://ficker-api.cloud

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ficker_test
DB_USERNAME=ficker
DB_PASSWORD=SENHA_DB

BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=fickerapi@gmail.com
MAIL_PASSWORD=SENHA_EMAIL_APP
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="fickerapi@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

SESSION_DOMAIN=
# Keep explicitly empty while auth remains Bearer-token based.
# Removing the line may reactivate Sanctum's localhost defaults.
SANCTUM_STATEFUL_DOMAINS=

FRONTEND_URL=https://ficker-front-psi.vercel.app

HASH_DRIVER=argon2id

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8675396145:TOKEN_TELEGRAM_BOT
TELEGRAM_WEBHOOK_SECRET=SUA_SENHA_SECRETA_CRIADA
TELEGRAM_LINK_CODE_TTL_MINUTES=10
TELEGRAM_SESSION_TTL_HOURS=72
TELEGRAM_TIMEZONE=America/Sao_Paulo
TELEGRAM_RATE_LIMIT_MAX_HITS=15
TELEGRAM_RATE_LIMIT_WINDOW_SECONDS=60

# Testing safeguards
# Never point this file to the main database.
# Recommended flow:
# 1. Copy this file to .env.testing
# 2. Create the database ficker_test in the MySQL container
# 3. Run tests with: php artisan test --env=testing
